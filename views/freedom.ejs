<%- include('partials/head') %>
<%- include('partials/sidebar') %>
<%- include('partials/navbar') %>

<div class="dashboard-container">
  <div class="view-header" style="margin-bottom: 15px;">Freedom Wall</div>

  <div id="freedomCreateBox" class="create-post-box">
    <div class="create-post-header">
      <div class="avatar-sm" id="freedomUserPic">
        <%= user ? user.full_name.charAt(0).toUpperCase() : 'G' %>
      </div>
      <button class="post-input-btn" id="openPostModalFreedomBtn">Share something with the community…</button>
    </div>
    <div class="type-selector" id="freedomTypeSel">
      <button class="type-badge selected" data-type="announcement">📢 Announcement</button>
      <button class="type-badge" data-type="event">🎉 Event</button>
      <button class="type-badge" data-type="update">📝 Update</button>
      <button class="type-badge" data-type="maintenance">🔧 Maintenance</button>
    </div>
  </div>

  <div class="filter-bar" id="freedomFilterBar">
    <button class="filter-chip active" data-filter="all">All</button>
    <button class="filter-chip" data-filter="announcement">📢 Announcement</button>
    <button class="filter-chip" data-filter="event">🎉 Event</button>
    <button class="filter-chip" data-filter="update">📝 Update</button>
    <button class="filter-chip" data-filter="maintenance">🔧 Maintenance</button>
  </div>

  <div id="freedomPostsContainer"></div>
</div>

<%- include('partials/footer') %>