<main class="main-content">
    <div class="top-navbar">
        <div class="active-pill">
            <span class="pulse-dot"></span>
            <span id="activeUserCount">0</span>&nbsp;online
        </div>
        <div class="user-menu" id="userMenuBtn">
            <div class="user-pill">
                <i class="far fa-user-circle"></i>
                <span id="dashboardUserName">
                    <%= user ? user.full_name.split(' ')[0] : 'Guest' %>
                </span>
                <span id="dashboardRoleBadge" class="role-badge">
                    <%= user ? (user.role.charAt(0).toUpperCase() + user.role.slice(1)) : 'Guest' %>
                </span>
                <i class="fas fa-chevron-down" style="font-size:0.65rem;"></i>
            </div>
            <div id="userDropdown" class="user-dropdown hidden">
                <a href="#" data-setting="profile"><i class="fas fa-user-edit"></i> Edit Profile</a>
                <% if (user && user.role === 'faculty') { %>
                    <a href="#" id="stationMenuItem" data-setting="station"><i class="fas fa-building"></i> Change Station</a>
                <% } %>
                <hr class="dropdown-divider">
                <a href="#" data-setting="password"><i class="fas fa-lock"></i> Change Password</a>
                <a href="#" data-setting="history"><i class="fas fa-history"></i> Activity Log</a>
                <hr class="dropdown-divider">
                <a href="/logout" id="logoutBtn" style="color:var(--red)"><i class="fas fa-sign-out-alt"></i> Sign Out</a>
            </div>
        </div>
    </div>

    <% if (!user || user.role === 'guest' || user.role === 'Guest') { %>
    <div id="guestModeBanner" style="background:linear-gradient(90deg,#fef3c7,#fef9ec);border-bottom:1px solid #fde68a;padding:0.5rem 1.75rem;display:flex;align-items:center;justify-content:space-between;flex-wrap:wrap;gap:0.5rem;">
        <div style="display:flex;align-items:center;gap:0.6rem;font-size:0.82rem;color:#92400e;">
            <i class="fas fa-eye" style="color:#d97706;"></i>
            <span><strong>Browsing as Guest</strong> — You can view content but cannot interact. Log in to like, comment, post, vote, and join groups.</span>
        </div>
        <div style="display:flex;gap:0.5rem;">
            <a href="/signup" style="background:#1a2e42;color:white;border:none;padding:0.35rem 0.9rem;border-radius:1rem;text-decoration:none;font-size:0.78rem;font-weight:700;">Sign Up</a>
            <a href="/login" style="background:white;color:#1a2e42;border:1.5px solid #e0eaf2;padding:0.35rem 0.9rem;border-radius:1rem;text-decoration:none;font-size:0.78rem;font-weight:600;">Log In</a>
        </div>
    </div>
    <% } %>