</main>
  </div> </div> <script>
  window.SERVER_USER = window.SERVER_USER = JSON.parse('<%- JSON.stringify(typeof user !== "undefined" ? user : null) %>');
</script>

<div id="postModal" class="modal-overlay hidden">
  <div class="modal-content">
    <div class="modal-title" id="modalTitle">Create Post</div>
    <select id="postTypeSelect">
      <option value="announcement">📢 Announcement</option>
      <option value="event">🎉 Event</option>
      <option value="update">📝 Update</option>
      <option value="maintenance">🔧 Maintenance</option>
    </select>
    <textarea id="postContentInput" rows="4" placeholder="What's on your mind?"></textarea>
    <div class="modal-buttons">
      <button class="cancel-btn" onclick="closeModal('postModal')">Cancel</button>
      <button class="btn-primary" id="submitPostBtn" style="margin:0;width:auto;padding:0.6rem 1.4rem;">Post</button>
    </div>
  </div>
</div>

<div id="addEventModal" class="modal-overlay hidden">
  <div class="modal-content sm">
    <div class="modal-title">📅 Add Event</div>
    <div class="form-group"><label>Event Name</label><input type="text" id="newEventName" placeholder="e.g. Campus Career Fair"></div>
    <div class="form-group"><label>Date & Time</label><input type="text" id="newEventDate" placeholder="e.g. May 10, 2:00 PM"></div>
    <div class="modal-buttons">
      <button class="cancel-btn" onclick="closeModal('addEventModal')">Cancel</button>
      <button class="btn-primary" onclick="submitNewEvent()" style="margin:0;width:auto;padding:0.6rem 1.4rem;">Add Event</button>
    </div>
  </div>
</div>

<div id="addPollModal" class="modal-overlay hidden">
  <div class="modal-content sm">
    <div class="modal-title">📊 Create Poll</div>
    <div class="form-group"><label>Question</label><input type="text" id="newPollQuestion" placeholder="Ask the campus something…"></div>
    <div class="form-group">
      <label>Options <span style="font-weight:400;color:var(--text-soft)">(min 2)</span></label>
      <div id="pollOptionsBuilder"></div>
      <button class="add-poll-option-btn" onclick="addPollOptionField()">＋ Add Option</button>
    </div>
    <div class="modal-buttons">
      <button class="cancel-btn" onclick="closeModal('addPollModal')">Cancel</button>
      <button class="btn-primary" onclick="submitNewPoll()" style="margin:0;width:auto;padding:0.6rem 1.4rem;">Create Poll</button>
    </div>
  </div>
</div>

<div id="votePollModal" class="modal-overlay hidden">
  <div class="modal-content sm">
    <div class="modal-title" id="pollModalQuestion"></div>
    <div id="pollOptionsContainer" style="display:flex;flex-direction:column;gap:0.5rem;margin-bottom:1rem;"></div>
    <div id="pollVoteResult" class="hidden" style="margin-bottom:1rem;"></div>
    <div class="modal-buttons">
      <button class="cancel-btn" onclick="closeModal('votePollModal')">Close</button>
      <button id="submitVoteBtn" class="btn-primary" onclick="submitVote()" style="margin:0;width:auto;padding:0.6rem 1.4rem;">Vote</button>
    </div>
  </div>
</div>

<div id="addOfficeModal" class="modal-overlay hidden">
  <div class="modal-content sm">
    <div class="modal-title">🏢 Add New Office</div>
    <div class="form-group"><label>Office Name</label><input type="text" id="newOfficeName" placeholder="e.g. Office of the Dean"></div>
    <div class="form-group"><label>Description</label><input type="text" id="newOfficeDesc" placeholder="Brief description of what this office does"></div>
    <div class="form-group"><label>Location</label><input type="text" id="newOfficeLoc" placeholder="e.g. Room 210, Main Building"></div>
    <div class="modal-buttons">
      <button class="cancel-btn" onclick="closeModal('addOfficeModal')">Cancel</button>
      <button class="btn-primary" onclick="submitNewOffice()" style="margin:0;width:auto;padding:0.6rem 1.4rem;">Add Office</button>
    </div>
  </div>
</div>

<div id="shareModal" class="modal-overlay hidden">
  <div class="modal-content sm">
    <div class="modal-title">Share Post</div>
    <p style="font-size:0.85rem;color:var(--text-soft);margin-bottom:1rem;">Choose where to share this post</p>
    <div id="shareOptions"></div>
    <div style="margin-top:0.75rem;padding-top:0.75rem;border-top:1px solid var(--border);">
      <div style="font-size:0.8rem;font-weight:600;color:var(--text-mid);margin-bottom:0.5rem;">Or copy link</div>
      <div style="display:flex;gap:0.5rem;">
        <input id="shareLinkInput" type="text" value="" readonly style="flex:1;padding:0.6rem 0.8rem;border:1.5px solid var(--border);border-radius:var(--radius-sm);font-family:inherit;font-size:0.83rem;background:var(--bg);">
        <button class="btn-secondary" onclick="copyShareLink()">Copy</button>
      </div>
    </div>
    <div class="modal-buttons" style="margin-top:0.75rem;">
      <button class="cancel-btn" onclick="closeModal('shareModal')">Close</button>
    </div>
  </div>
</div>

<div id="createGroupModal" class="modal-overlay hidden">
  <div class="modal-content sm">
    <div class="modal-title">👥 Create Group / Org</div>
    <div class="form-group"><label>Group Name</label><input type="text" id="newGroupName" placeholder="e.g. Computer Science Society"></div>
    <div class="form-group"><label>Category</label><select id="newGroupCategory"><option value="Student Organization">Student Organization</option><option value="Academic Club">Academic Club</option><option value="Sports">Sports</option><option value="Arts & Culture">Arts & Culture</option><option value="Community Service">Community Service</option><option value="Tech & Innovation">Tech & Innovation</option><option value="Other">Other</option></select></div>
    <div class="form-group"><label>Description</label><textarea id="newGroupDesc" rows="2" placeholder="What is this group about?"></textarea></div>
    <div class="form-group"><label>Privacy</label><select id="newGroupPrivacy"><option value="public">🌐 Public — anyone can see & join</option><option value="private">🔒 Private — members only</option></select></div>
    <div class="modal-buttons">
      <button class="cancel-btn" onclick="closeModal('createGroupModal')">Cancel</button>
      <button class="btn-primary" onclick="submitCreateGroup()" style="margin:0;width:auto;padding:0.6rem 1.4rem;">Create Group</button>
    </div>
  </div>
</div>

<div id="guestPromptModal" class="modal-overlay hidden">
  <div class="modal-content sm" style="text-align:center;padding:2rem 1.75rem;">
    <div style="font-size:2.5rem;margin-bottom:0.75rem;">🔒</div>
    <div class="modal-title" style="justify-content:center;">Sign in to interact</div>
    <p style="font-size:0.88rem;color:var(--text-mid);margin-bottom:1.5rem;line-height:1.6;">
      You're browsing as a guest. Create a free account or log in to like, comment, post, vote, join groups, and more.
    </p>
    <div style="display:flex;flex-direction:column;gap:0.6rem;">
      <a href="/login" class="btn-primary" style="margin:0;text-decoration:none;"><i class="fas fa-sign-in-alt"></i> Log In</a>
      <a href="/signup" class="btn-secondary" style="width:100%;justify-content:center;display:flex;text-decoration:none;"><i class="fas fa-user-plus"></i> Create Account</a>
      <button class="cancel-btn" onclick="closeModal('guestPromptModal')" style="width:100%;">Maybe later</button>
    </div>
  </div>
</div>

<div id="toast" class="toast"></div>

<script src="/js/app.js"></script>
</body>
</html>