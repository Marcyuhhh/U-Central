<%- include('partials/head') %>
<%- include('partials/sidebar') %>
<%- include('partials/navbar') %>

<div class="dashboard-container">
  <div class="offices-header">
    <div>
      <div class="view-header" style="margin-bottom:0.2rem;">Offices</div>
      <p style="font-size:0.83rem;color:var(--text-soft);">Browse campus offices and their announcements</p>
    </div>
    
    <% if (user && user.role === 'faculty') { %>
    <button class="btn-primary" id="addOfficeBtn" style="width:auto;padding:0.6rem 1.2rem;margin:0;font-size:0.85rem;">
      <i class="fas fa-plus"></i> Add Office
    </button>
    <% } %>
  </div>

  <div class="search-wrapper">
    <i class="fas fa-search search-icon"></i>
    <input type="text" id="officeSearchInput" class="search-input" placeholder="Search offices…">
  </div>

  <!-- OFFICES GRID -->
  <div class="offices-grid" id="officesGrid"></div>
</div>

<%- include('partials/footer') %>